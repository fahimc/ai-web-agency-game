{
  "name": "tiny-ai-office-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run templates:previews",
    "build": "vite build",
    "agency:cli": "node tools/agency-cli.mjs",
    "agency:cli:smoke": "node tools/agency-cli.mjs smoke",
    "test:scripted-agency": "node tests/scripted-agency-regression.mjs",
    "test:design-options": "node tests/design-options-regression.mjs",
    "test:ui-visibility": "node tests/ui-visibility-regression.mjs",
    "test:template-review": "node tests/template-review-regression.mjs",
    "templates:audit": "node tools/audit-template-sources.mjs",
    "templates:download": "node tools/download-template-library.mjs",
    "templates:generate": "node tools/generate-template-knowledge.mjs",
    "templates:previews": "node tools/export-template-previews.mjs",
    "templates:sync": "npm run templates:audit && npm run templates:download && npm run templates:generate",
    "preview": "vite preview --host 127.0.0.1",
    "netlify:status": "netlify status",
    "netlify:link": "netlify link",
    "deploy": "npm run build && netlify deploy --dir=dist",
    "deploy:prod": "npm run build && netlify deploy --prod --dir=dist"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
